#!/usr/bin/env bb

;; Tests: bb local/bin/test-a

(require '[babashka.classpath :as cp])
(require '[babashka.fs :as fs])

(let [script-file (or (System/getProperty "babashka.file") *file*)
      script-path (fs/real-path script-file)
      src-dir (str (fs/path (fs/parent (fs/parent script-path)) "src" "clj"))]
  (cp/add-classpath src-dir))

(require '[djwhitt.archive :as archive])

(System/exit (apply archive/-main *command-line-args*))

;; vim:ft=clojure:

#!/usr/bin/env bash
# Interactively triage loose files with fzf previews.
# Scans configured roots, skips any git/git-annex repo, lists oldest first.
# Keys: enter/ctrl-o open, ctrl-a archive to ~/Annex/inbox, ctrl-t trash,
#       ctrl-r reload, esc quit.

set -euo pipefail

ROOTS=(
  "$HOME/Downloads"
  "$HOME/Scratch"
)
TRASH="$HOME/.trash"

# Directory basenames to prune entirely (build artifacts, caches, etc).
# Tune as needed — add extracted-archive dirs that you'd rather handle as a unit.
NOISE_DIRS=(
  node_modules
  __pycache__
  .venv
  .direnv
  .cache
  target
  dist
  build
  .next
)

SCRIPT=$(readlink -f "$0")
export SCRIPT

list_files() {
  local existing=()
  local r
  for r in "${ROOTS[@]}"; do
    [[ -d "$r" ]] && existing+=("$r")
  done
  [[ ${#existing[@]} -eq 0 ]] && return 0

  local noise_expr=()
  local n
  for n in "${NOISE_DIRS[@]}"; do
    noise_expr+=( -o \( -type d -name "$n" \) -prune )
  done

  find "${existing[@]}" \
    \( -type d -exec test -e {}/.git \; \) -prune \
    "${noise_expr[@]}" \
    -o -type f -printf '%T@\t%p\n' 2>/dev/null \
    | sort -n | cut -f2-
}

archive_files() {
  local f
  for f in "$@"; do
    [[ -f "$f" ]] || continue
    a "$f" || echo "archive failed: $f" >&2
  done
}

trash_files() {
  (( $# )) || return 0
  printf 'Trash %d file(s):\n' "$#"
  printf '  %s\n' "$@"
  local ans
  read -r -p "Confirm [y/N] " ans
  [[ "$ans" == "y" || "$ans" == "Y" ]] || { echo "Cancelled."; return 0; }

  mkdir -p "$TRASH"
  local f ts base dest i
  for f in "$@"; do
    [[ -f "$f" ]] || continue
    ts=$(date -r "$f" +%Y%m%dT%H%M%S 2>/dev/null || date +%Y%m%dT%H%M%S)
    base=$(basename -- "$f")
    dest="$TRASH/$ts-$base"
    i=1
    while [[ -e "$dest" ]]; do
      dest="$TRASH/$ts-$i-$base"
      i=$((i + 1))
    done
    mv -- "$f" "$dest" || echo "trash failed: $f" >&2
  done
}

render_image() {
  # Render an image via kitty's Unicode Placeholder Protocol — actual pixels,
  # anchored to placeholder characters that fzf can redraw over. Falls back
  # to chafa symbol mode if kitten icat fails.
  local img=$1 w=$2 h=$3
  kitten icat --unicode-placeholder --stdin no --transfer-mode file \
    --place "${w}x${h}@0x0" -- "$img" 2>/dev/null \
    || chafa -f symbols -s "${w}x${h}" -- "$img" 2>/dev/null
}

preview_file() {
  local file=$1
  [[ -r "$file" ]] || { echo "unreadable: $file"; return 0; }

  local w=${FZF_PREVIEW_COLUMNS:-80}
  local h=${FZF_PREVIEW_LINES:-40}
  local mime
  mime=$(file -bL --mime-type -- "$file" 2>/dev/null || echo unknown)

  case "$mime" in
    image/*)
      render_image "$file" "$w" "$h"
      ;;
    application/pdf)
      local tmp
      tmp=$(mktemp --suffix=.png)
      pdftoppm -f 1 -l 1 -r 150 -png -- "$file" "${tmp%.png}" 2>/dev/null
      render_image "$tmp" "$w" "$h"
      rm -f "$tmp"
      ;;
    video/*)
      local tmp
      tmp=$(mktemp --suffix=.png)
      ffmpegthumbnailer -i "$file" -o "$tmp" -s 0 -q 8 2>/dev/null
      render_image "$tmp" "$w" "$h"
      rm -f "$tmp"
      ;;
    audio/*)
      exiftool -- "$file"
      ;;
    text/markdown)
      glow -s dark -w "$w" -- "$file"
      ;;
    text/html|application/xhtml+xml)
      w3m -dump -cols "$w" -T text/html "$file"
      ;;
    application/json)
      jq -C . -- "$file" 2>/dev/null || bat --color=always --style=plain -- "$file"
      ;;
    application/zip|application/x-tar|application/gzip|application/x-bzip2|application/x-xz|application/x-7z-compressed|application/vnd.rar)
      atool -l -- "$file"
      ;;
    application/vnd.openxmlformats-officedocument.*|application/vnd.oasis.opendocument.*|application/msword|application/vnd.ms-*)
      echo "(office doc — open with ctrl-o for full view)"
      echo
      exiftool -- "$file"
      ;;
    text/*|application/javascript|application/x-shellscript|application/xml)
      bat --color=always --style=plain --paging=never --terminal-width="$w" -- "$file"
      ;;
    *)
      exiftool -- "$file"
      ;;
  esac
}

case "${1:-}" in
  --list)    list_files; exit 0 ;;
  --archive) shift; archive_files "$@"; exit 0 ;;
  --trash)   shift; trash_files "$@"; exit 0 ;;
  --preview) shift; preview_file "$@"; exit 0 ;;
esac

list_files | fzf \
  --multi \
  --no-sort \
  --height=100% --reverse \
  --preview '"$SCRIPT" --preview {}' \
  --preview-window=right:60%:wrap \
  --header='enter/ctrl-o: open · ctrl-a: archive · ctrl-t: trash · ctrl-r: reload · esc: quit' \
  --bind 'ctrl-a:execute("$SCRIPT" --archive {+})+reload("$SCRIPT" --list)' \
  --bind 'ctrl-t:execute("$SCRIPT" --trash {+})+reload("$SCRIPT" --list)' \
  --bind 'ctrl-o:execute-silent(xdg-open {} >/dev/null 2>&1 &)' \
  --bind 'enter:execute-silent(xdg-open {} >/dev/null 2>&1 &)' \
  --bind 'ctrl-r:reload("$SCRIPT" --list)' \
  >/dev/null || true
